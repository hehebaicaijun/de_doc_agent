//case3: entry create clc_req_pe + hnf_top send bypass request
{signal: [
    {name: 'clk'                  , wave: 'p.......'},
    
    ['hnfiif',
        ['creat pe',
            {name: 'hnf_entry_clc_req'    , wave:'0=0.....'},//entry0~x send req
            {name: 'clc_req_vld'          , wave:'010.....'},//exist entry send req
            {name: 'clc_req_pe_idle'      , wave:'1.0.1...'},//clc_req_pe is idle
            {name: 'clc_req_pe_crt_en'    , wave:'010.....'},//set clc_req_pe
        ],

        ['pe info',
            {name: 'clc_req_pe_vld'       , wave:'0.1.0...'},
            {name: 'clc_req_pe_sel'       , wave:'x.2.x...'},
        ],

        ['pop pe',
            {name: 'clc_req_pe_clr_en'    , wave:'0.......'},//byp hit
            {name: 'clc_hnf_req_grant'    , wave:'0..10...'},//clc pipe accept req
            {name: 'clc_req_pe_pop_en'    , wave:'0..10...'},//clr clc_req_pe
        ],
        
        ['can byp',
            {name: 'hnf_clc_req_pick'     , wave:'0.1.0...'},
            {name: 'hnf_clc_req_byq'      , wave:'1.0.1...'},
            {name: 'hnf_clc_req_vld'      , wave:'0.1.0.'},
        ],
    ],
     {name: 'clc_req_type(not real signal)', wave:'xxx2xxxxxxx', data:['byp','entry']},
    ['hnf_top',
        ['can byp',
            //{name: 'xr0_crt_req'           , wave:'1..........'},
            //{name: 'xr0_can_byp'           , wave:'1..........'},
            {name: 'hnf_xrt_byp_grant'     , wave:'0.....1....'},
            {name: 'hnf_xrt_req0_grant'    , wave:'0......1...'},
            {name: 'hnf_xrt_byp_ar_set'    , wave:'0.....1....'},
            {name: 'hnf_xrt_byp_ar_clr'    , wave:'0......1...'},
            {name: 'hnf_xrt_byp_ar    '    , wave:'0......10..'},
            {name: 'hnf_xrt_byp_req    '   , wave:'0'},
        ],
    ],
]}
