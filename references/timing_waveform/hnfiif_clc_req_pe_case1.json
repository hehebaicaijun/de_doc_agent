//case1: byp hit, clear the clc_req_pe

{signal: [
    {name: 'clk'                  , wave: 'p|......'},
    
    ['byp hit',
        {name: 'hnf_entry_clc_req_clr', wave:'0|=0....'},
        {name: 'clc_req_pe_sel'       , wave:'0|=0....'},
    ],

    ['pop pe',
        {name: 'clc_req_pe_clr_en'    , wave:'0|10....'},//byp hit
        {name: 'clc_hnf_req_grant'    , wave:'0|......'},//clc pipe accept req
        {name: 'clc_req_pe_pop_en'    , wave:'0|10....'},//clr clc_req_pe
    ],

    ['pe info',
        {name: 'clc_req_pe_vld'       , wave:'1|.0....'},
        {name: 'clc_req_pe_sel'       , wave:'2|.x....'},
        {name: 'clc_req_pe_bus'       , wave:'2|.x....'},
        {name: 'clc_req_pe_misc'      , wave:'2|.x....'},
    ],
]}