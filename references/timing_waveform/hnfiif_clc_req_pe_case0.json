//case0: set the clc_req_pe
{signal: [
    {name: 'clk'                  , wave: 'p......|'},
    
    ['creat pe',
        {name: 'hnf_entry_clc_req'    , wave:'0=0....|'},//entry0~x send req
        {name: 'clc_req_vld'          , wave:'010....|'},//exist entry send req
        {name: 'clc_req_pe_idle'      , wave:'1.0....|'},//clc_req_pe is idle
        {name: 'clc_req_pe_crt_en'    , wave:'010....|'},//set clc_req_pe
    ],

    ['pe info',
        {name: 'clc_req_pe_vld'       , wave:'0.1....|'},
        {name: 'clc_req_pe_sel'       , wave:'x.2....|'},
        {name: 'clc_req_pe_bus'       , wave:'x.2....|'},
        {name: 'clc_req_pe_misc'      , wave:'x.2....|'},
    ],

    ['can byp',
        {name: 'hnf_clc_req_pick'     , wave:'0.1....|'},
        {name: 'hnf_clc_req_byq'      , wave:'1.0....|'},
        {name: 'hnf_clc_req_vld'      , wave:'0.1....|'},
    ]
]}